# Copy to .env and fill only the variables you need.

# ElevenLabs TTS (recommended for production voiceover)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional custom base URL or proxy for ElevenLabs-compatible gateways.
ELEVENLABS_BASE_URL=
ELEVENLABS_PROXY_URL=
ELEVENLABS_PROXY_USER=
ELEVENLABS_PROXY_PASS=

# Optional fallback TTS
YANDEX_SPEECHKIT_API_KEY=

# Optional image generation for article illustrations
OPENAI_API_KEY=
